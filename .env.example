# You normally never edit this file — the setup wizard writes .env for you.
# Copy to .env only if you're doing things by hand.

# Civitai API key: civitai.com/user/account -> API Keys -> Add API key
CIVITAI_API_TOKEN=

# Hugging Face token (Read): huggingface.co/settings/tokens
# Only needed for gated models (the Flux VAE). Also click "Agree and access
# repository" at huggingface.co/black-forest-labs/FLUX.1-schnell once.
HF_TOKEN=

# Path to your ComfyUI folder (the one containing main.py)
COMFY_DIR=
